@model MatchFixer_Web_App.Areas.Admin.ViewModels.Teams.TeamEditorVm

<div class="team-editor-wrapper">

    <div class="team-editor-title">
        @Model.Name
    </div>

    <div class="team-editor-layout">

        <!-- LEFT -->
        <div class="team-editor-logo-column">

	        <div class="team-logo-card">
		        <img src="@Model.EffectiveLogoUrl"
		             alt="@Model.Name" />
	        </div>

	        @if (!string.IsNullOrWhiteSpace(Model.WikiImageUrl))
	        {
		        <div class="wiki-logo-card">
			        <img src="@Model.WikiImageUrl"
			             alt="Wikipedia Image"
			             onerror="this.closest('.wiki-logo-card').style.display='none';" />
		        </div>
	        }

        </div>

        <!-- RIGHT -->
        <div class="team-editor-fields">
            <form id="teamEditorForm">
	            @Html.AntiForgeryToken()
                <input type="hidden" name="TeamId" value="@Model.TeamId" />

                <div class="mb-3">
                    <label>Team name</label>
                    <input class="form-control"
                           name="Name"
                           value="@Model.Name" />
                </div>

                <div class="mb-3">
                    <label>League</label>
                    <select class="form-select" name="LeagueId">
                        @foreach (var l in Model.Leagues)
                        {
                            <option value="@l.Id"
                                    selected="@(l.Id == Model.LeagueId)">
                                @l.Name
                            </option>
                        }
                    </select>
                </div>

	            <div class="team-editor-aliases">
		            <label class="form-label">Aliases</label>

		            <div id="aliasList">
			            @if (Model.Aliases.Any())
			            {
				            @for (var i = 0; i < Model.Aliases.Count; i++)
				            {
					            <div class="team-alias-row">
						            <input class="form-control"
						                   name="Aliases[@i].Alias"
						                   value="@Model.Aliases[i].Alias" />
					            </div>
				            }
			            }
			            else
			            {
				            @if (!Model.Aliases.Any())
				            {
					            <div class="team-alias-row">
						            <input class="form-control"
						                   name="Aliases[0].Alias"
						                   placeholder="Add an alias…" />
					            </div>
				            }
			            }
		            </div>

	            </div>

	            <hr />

	            <h5 class="text-warning mb-2 text-center">
		            Wikipedia Information
	            </h5>

	            <div class="mb-3">
		            <label class="form-label">Wikipedia Summary</label>

		            <textarea class="form-control "rows="4" name="WikiSummary">@Model.WikiSummary</textarea>
	            </div>

	            <div class="mb-3">
		            <label class="form-label">Wikipedia Image</label>

		            <input class="form-control"
		                   name="WikiImageUrl"
		                   value="@Model.WikiImageUrl" />

	            </div>

	            <div class="mb-3">
		            <label class="form-label">Wikipedia URL</label>

		            <input class="form-control"
		                   name="WikipediaUrl"
		                   value="@Model.WikipediaUrl" />
	            </div>

	            @if (Model.WikiLastUpdatedUtc != null)
	            {
		            <div class="d-flex justify-content-center align-items-center">
			            <label class="text-info badge justify-content-center">
				            Last Updated:
				            @Model.WikiLastUpdatedUtc.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")
			            </label>
		            </div>
	            }

	            <div class="team-editor-save">
		            <button class="btn btn-primary">
			            Save team
		            </button>
	            </div>
            </form>
        </div>

    </div>

</div>

