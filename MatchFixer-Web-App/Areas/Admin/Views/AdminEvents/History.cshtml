@using MatchFixer_Web_App.Areas.Admin.ViewModels.Events
@model PaginatedEventList<MatchFixer_Web_App.Areas.Admin.ViewModels.Events.AdminEventOverviewDto>
@{
	Layout = "/Areas/Admin/Views/Shared/_Layout.Admin.cshtml";
	ViewData["Title"] = "Events History";

	var filters = ViewBag.Filters as AdminEventHistoryFilters ?? new AdminEventHistoryFilters();

	// Aggregates are pre-computed across ALL filtered events in the service
	var totalProfit       = Model.AllEventsProfit;
	var totalLoss         = Model.AllEventsLoss;
	var totalPositive     = Model.AllEventsPositive;
	var totalUserWinnings = Model.AllEventsPayout;

	// League breakdown across ALL filtered events (pre-computed in service)
	var leagueStats = Model.AllEventsLeagueStats;


	var leagueLogos = new Dictionary<string, int>
	{
		["Premier League"] = 39,
		["Parva Liga"] = 172,
		["Bundesliga"] = 78,
		["La Liga"] = 140,
		["Eredivisie"] = 88,
		["Ligue 1"] = 61,
		["Serie A"] = 135,
		["Liga Portugal"] = 94,
		["Swiss League"] = 207,
		["Polish League Ekstraklasa"] = 106
	};

	var today = DateTime.Today.ToString("yyyy-MM-dd");

	var teamStats = ViewBag.TeamStats as List<AdminTeamBettingStatsDto>
	                ?? new List<AdminTeamBettingStatsDto>();

	var mostBetTeams = teamStats.OrderByDescending(t => t.TotalBets).Take(10);
	var usersLostMostOn = teamStats.OrderByDescending(t => t.Profit).Take(10);
	var usersWonMostOn = teamStats.OrderBy(t => t.Profit).Take(10);

}

<h2 class="mb-4 match-events-history-header">Match Events History</h2>

<div class="accordion mb-4" id="dashboardAccordion">

	<!-- COMPANY PERFORMANCE -->
	<div class="accordion-item">
		<h2 class="accordion-header" id="headingPerf">
			<button class="accordion-button" type="button" data-bs-toggle="collapse"
					data-bs-target="#collapsePerf" aria-expanded="true">
				Company Performance Overview
			</button>
		</h2>

		<div id="collapsePerf" class="accordion-collapse collapse show">
			<div class="accordion-body">

				<div class="row mb-4">

					<!-- Total Net Profit -->
					<div class="col-lg-4 col-md-6 col-12">
						<div class="card shadow-sm border-0 event-history-card" style="border-left: 6px solid #28a745;">
							<div class="card-body d-flex align-items-center gap-3 justify-content-center">
								<i class="bi bi-graph-up text-success" style="font-size: 2rem;"></i>
								<div>
									<h6 class="text-muted mb-1">Total Net Profit</h6>
									<h4 class="fw-bold text-success text-center">€@totalProfit.ToString("F2")</h4>
								</div>
							</div>
						</div>
					</div>

					<!-- Total Loss -->
					<div class="col-lg-4 col-md-6 col-12">
						<div class="card shadow-sm border-0 event-history-card" style="border-left: 6px solid #dc3545;">
							<div class="card-body d-flex align-items-center gap-3 justify-content-center">
								<i class="bi bi-graph-down text-danger" style="font-size: 2rem;"></i>
								<div>
									<h6 class="text-muted mb-1">Total Loss</h6>
									<h4 class="fw-bold text-danger text-center">€@totalLoss.ToString("F2")</h4>
								</div>
							</div>
						</div>
					</div>

					<!-- Total Winning Events -->
					<div class="col-lg-4 col-md-6 col-12">
						<div class="card shadow-sm border-0 event-history-card" style="border-left: 6px solid #0d6efd;">
							<div class="card-body d-flex align-items-center gap-3 justify-content-center">
								<i class="bi bi-cash-coin text-primary" style="font-size: 2rem;"></i>
								<div>
									<h6 class="text-muted mb-1">Total Winning Events</h6>
									<h4 class="fw-bold text-primary text-center">€@totalPositive.ToString("F2")</h4>
								</div>
							</div>
						</div>
					</div>
					
					<!-- Total User Winnings -->
					
					<div class="col-12 d-flex justify-content-center mt-2">
						<div class="card shadow-sm border-0 event-history-card" style="border-left: 6px solid #6f42c1; width: 350px;">
							<div class="card-body d-flex align-items-center gap-3 justify-content-center">
								<i class="bi bi-gift text-purple" style="font-size: 2rem; color:#6f42c1;"></i>
								<div>
									<h6 class="text-muted mb-1">Total User Winnings</h6>
									<h4 class="fw-bold text-center" style="color:#6f42c1">€@totalUserWinnings.ToString("F2")</h4>
								</div>
							</div>
						</div>
					</div>

				</div>

			</div>
		</div>

	</div>
	<!-- PROFIT BY LEAGUE -->
	<div class="accordion-item">
		<h2 class="accordion-header" id="headingLeague">
			<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
			        data-bs-target="#collapseLeague">
				Profit by League
			</button>
		</h2>

		<div id="collapseLeague" class="accordion-collapse collapse">
			<div class="accordion-body">

				@if (leagueStats.Any())
				{
					<div class="row g-3 mb-4">
						@foreach (var league in leagueStats)
						{
							var color = league.TotalProfit > 0 ? "text-success"
								: league.TotalProfit < 0 ? "text-danger"
								: "text-warning";

							var borderColor = league.TotalProfit > 0 ? "#198754"
								: league.TotalProfit < 0 ? "#dc3545"
								: "#ffc107";

							<div class="col-md-4">
								<div class="card shadow-sm border-0" style="border-left: 6px solid @borderColor;">

									<div class="card-body text-center">

										<!-- League Logo -->
										@{
											int logoId = leagueLogos.ContainsKey(league.League) ? leagueLogos[league.League] : 39;
											string logoUrl = $"https://media.api-sports.io/football/leagues/{logoId}.png";
										}
										
										@if (league.League == "Rest of World")
										{
											<span style="font-size: 1.8rem;">🌍</span>
										}
										else if (league.League == "FIFA World Cup")
										{
											<img src="/images/live-events/fifa_world_cup.png"
											     alt="FIFA World Cup"
											     class="img-fluid mb-2"
											     style="height:40px; width:auto; object-fit:contain;" />
										}
					else
										{
											<img src="@logoUrl"
											     alt="@league.League logo"
											     class="img-fluid mb-2"
											     style="height:40px; width:auto; object-fit:contain;" />
										}
										<!-- League name -->
										<h6 class="mb-1">@league.League</h6>

										<!-- Profit -->
										<div class="fw-bold @color">
											€@league.TotalProfit.ToString("F2")
										</div>

										<!-- Event count -->
										<small class="text-muted">@league.EventCount events</small>

									</div>

								</div>
							</div>

						}
					</div>
				}
				else
				{
					<p class="text-muted fst-italic">No league data available.</p>
				}

			</div>
		</div>
	</div>
	<!-- TEAM BETTING INSIGHTS -->
	<div class="accordion-item">
		<h2 class="accordion-header">
			<button class="accordion-button collapsed" data-bs-toggle="collapse"
					data-bs-target="#collapseTeams">
				Team Betting Insights
			</button>
		</h2>

		<div id="collapseTeams" class="accordion-collapse collapse">
			<div class="accordion-body">

				<div class="row g-4">

					<!-- Most Bet On -->
					<div class="col-md-4">
						<h6 class="text-center fw-bold mb-3">🔥 Most Bet On</h6>
						@foreach (var t in mostBetTeams)
						{
							<div class="d-flex justify-content-between align-items-center border rounded p-2 mb-2" style="font-size: 0.75em;">
								<div class="d-flex align-items-center gap-2">
									<img src="@t.LogoUrl" height="26" />
									<span>@t.TeamName</span>
								</div>
								<span class="badge bg-info">@t.TotalBets</span>
							</div>
						}
					</div>

					<!-- Users Lost Most -->
					<div class="col-md-4">
						<h6 class="text-center fw-bold mb-4 text-success">😈 Users Lost Most</h6>
						@foreach (var t in usersLostMostOn)
						{
							<div class="d-flex justify-content-between align-items-center border rounded p-2 mb-2" style="font-size: 0.75em;">
								<div class="d-flex align-items-center gap-2">
									<img src="@t.LogoUrl" height="26" />
									<span>@t.TeamName</span>
								</div>
								<span class="fw-bold text-success">
									+€@t.Profit.ToString("F2")
								</span>
							</div>
						}
					</div>

					<!-- Users Won Most -->
					<div class="col-md-4">
						<h6 class="text-center fw-bold mb-4 text-danger">🏆 Users Won Most</h6>
						@foreach (var t in usersWonMostOn)
						{
							<div class="d-flex justify-content-between align-items-center border rounded p-2 mb-2" style="font-size: 0.75em;">
								<div class="d-flex align-items-center gap-2">
									<img src="@t.LogoUrl" height="26" />
									<span>@t.TeamName</span>
								</div>
								<span class="fw-bold text-danger">
									-€@Math.Abs(t.Profit).ToString("F2")
								</span>
							</div>
						}
					</div>

				</div>

			</div>
		</div>
	</div>

</div>

<div class="background-profile"></div>

<form method="get" class="row g-3 mb-4">
	<input type="hidden" name="page" value="1" />
	<input type="hidden" name="pageSize" value="@Model.PageSize" />

	<div class="col-md-3">
		<label class="form-label">From Date</label>
		<input type="date" name="FromDate" class="form-control" value="@today" />
	</div>

	<div class="col-md-3">
		<label class="form-label">To Date</label>
		<input type="date" name="ToDate" class="form-control" value="@today" />
	</div>

	<div class="col-md-3">
		<label class="form-label">League</label>
		<input type="text" name="League" class="form-control" placeholder="Premier League" />
	</div>

	<div class="col-md-3 d-flex align-items-end">
		<button class="btn btn-primary w-100">Filter</button>
	</div>
</form>

<ul class="nav nav-pills justify-content-center mb-3" id="eventFilterPills">
	<li class="nav-item">
		<button class="nav-link active" data-filter="all">All Events</button>
	</li>
	<li class="nav-item">
		<button class="nav-link" data-filter="concluded">Concluded</button>
	</li>
	<li class="nav-item">
		<button class="nav-link" data-filter="cancelled">Cancelled</button>
	</li>
</ul>

<div class="table-scroll-container">
	
	<div class="table-scroll-container-inner">
		<table class="table table-bordered table-hover admin-events-historical-table" style="font-size: 0.85em;">
			<thead class="table-light">
				<tr>
					<th class="text-center">Match</th>
					<th class="text-center">Date</th>
					<th class="text-center">Result</th>
					<th class="text-center">Bets</th>
					<th class="text-center">Stake</th>
					<th class="text-center">Payout</th>
					<th class="text-center">Profit</th>
					<th class="text-center"></th>
				</tr>
			</thead>

			<tbody>
				@foreach (var e in Model.Items)
				{
					<tr class="event-row event-row-main"
						data-status="@(e.IsCancelled
					 	 ? "cancelled"
					 	 : (e.HomeScore.HasValue && e.AwayScore.HasValue ? "concluded" : "pending")
	         	         )">

					<td class="text-center">@e.MatchName</td>
					<td class="text-center">
						@(e.MatchDate.HasValue
												? TimeZoneInfo.ConvertTimeFromUtc(
												e.MatchDate.Value,
												TimeZoneInfo.FindSystemTimeZoneById("FLE Standard Time")
												).ToString("g")
												: "TBA")
					</td>
					<td class="text-center">
						@if (e.IsCancelled)
							{
								<span class="badge bg-secondary">Cancelled</span>
							}
							else
							{
								<span>@e.HomeScore - @e.AwayScore@if (e.HomeWonOnPenalties.HasValue) { <span class="badge bg-warning text-dark ms-1" title="Decided on penalties">P</span> }</span>
							}
						</td>
						<td class="text-center">@e.TotalBets</td>
						<td class="fw-bold text-center @(
							 e.TotalStake > 0
								 ? "text-success"
								 : e.TotalStake == 0
									 ? "text-warning"
									 : "text-danger"
	               								   )">
						€@e.TotalStake.ToString("F2")
					</td>
					<td class="fw-bold text-center @(e.TotalPayout >= 0 ? "text-success" : "text-danger")">
						€@e.TotalPayout.ToString("F2")
					</td>
					<td class="fw-bold text-center @(e.Profit >= 0 ? "text-success" : "text-danger")">
						€@e.Profit.ToString("F2")
					</td>
					<td class="text-center">

							<div class="d-flex justify-content-center align-items-center gap-2">

								<!-- LOGS -->
							@if (e.Logs.Any())
								{
									<span class="badge bg-warning text-dark"
										  title="@($"{e.Logs.Count} changes recorded")">
										<i class="bi bi-clipboard-data"></i> @e.Logs.Count
									</span>
								}
								else
								{
									<span class="text-muted" title="No changes recorded">
										<i class="bi bi-clipboard-data"></i>
									</span>
								}

								<!-- DETAILS BUTTON -->
								<button class="btn-pill"
										onclick="toggleEvent(this)">
									Details
								</button>

							</div>

						</td>
					</tr>

					<tr class="event-details-row">

						<td colspan="8" style="background-color: rgba(0, 0, 0, 0.3); padding: 1em 0.75em; border-radius: 14px; margin-top: 3em;">
							<div id="details_@e.EventId" class="event-details-wrapper">

								<div class="p-3 admin-event-information">

									<!-- BETS -->
									<div class="event-section">
										@if (e.Bets.Any())
										{
											@await Html.PartialAsync("_EventBetsPartial", e.Bets)
										}
										else
										{
											<p class="text-muted fst-italic text-center">
												No bets were placed on this event.
											</p>
										}
									</div>

									<!-- LOGS -->
									<div class="event-section">
										@if (e.Logs.Any())
										{
											@await Html.PartialAsync("_EventLogsPartial", e.Logs)
										}
										else
										{
											<p class="text-muted fst-italic text-center">
												No changes were recorded for this event.
											</p>
										}
									</div>

								</div>
							</div>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>



	@{
		var p     = Model.Page;
		var total = Model.TotalPages;
		const int window = 10;

		var wStart = ((p - 1) / window) * window + 1;
		var wEnd   = Math.Min(wStart + window - 1, total);
		var prevWinStart = Math.Max(1, wStart - window);
		var nextWinStart = Math.Min(((total - 1) / window) * window + 1, wStart + window);

		string PageLink(int i) => Url.Action("History", "AdminEvents", new
		{
			area      = "Admin",
			page      = i,
			pageSize  = filters.PageSize,
			FromDate  = filters.FromDate?.ToString("yyyy-MM-dd"),
			ToDate    = filters.ToDate?.ToString("yyyy-MM-dd"),
			League    = filters.League
		})!;
	}

	@if (total > 1)
	{
		<div class="d-flex justify-content-center mt-3 mb-2">
			<ul class="pagination pagination-ivm mb-0">

				<li class="page-item @(p == 1 ? "disabled" : null)">
					<a class="page-link" href="@(p == 1 ? "#" : PageLink(1))" aria-label="First">&laquo;</a>
				</li>
				<li class="page-item @(p == 1 ? "disabled" : null)">
					<a class="page-link" href="@(p == 1 ? "#" : PageLink(p - 1))" aria-label="Previous">&lsaquo;</a>
				</li>

				@if (wStart > 1)
				{
					<li class="page-item">
						<a class="page-link" href="@PageLink(prevWinStart)" title="Previous 10">…</a>
					</li>
				}

				@for (var i = wStart; i <= wEnd; i++)
				{
					<li class="page-item @(i == p ? "active" : null)">
						<a class="page-link" href="@PageLink(i)">@i</a>
					</li>
				}

				@if (wEnd < total)
				{
					<li class="page-item">
						<a class="page-link" href="@PageLink(nextWinStart)" title="Next 10">…</a>
					</li>
				}

				<li class="page-item @(p == total ? "disabled" : null)">
					<a class="page-link" href="@(p == total ? "#" : PageLink(p + 1))" aria-label="Next">&rsaquo;</a>
				</li>
				<li class="page-item @(p == total ? "disabled" : null)">
					<a class="page-link" href="@(p == total ? "#" : PageLink(total))" aria-label="Last">&raquo;</a>
				</li>

			</ul>
		</div>
		<p class="text-center text-muted" style="font-size:0.8em;">
			Page @p of @total &nbsp;·&nbsp; @Model.TotalCount total events
		</p>
	}

</div>
<script>
	document.addEventListener("DOMContentLoaded", () => {

	const labels = @Html.Raw(Json.Serialize(Model.Items.Select(m => m.MatchDate.HasValue
			               ? m.MatchDate.Value.ToString("yyyy-MM-dd")
			               : "TBA")
               ));
		const profits = @Html.Raw(Json.Serialize(Model.Items.Select(m => m.Profit)));

		const chartEl = document.getElementById("profitChart");
		if (chartEl) {
			new Chart(chartEl, {
				type: 'line',
				data: {
					labels: labels,
					datasets: [{
						label: 'Profit',
						data: profits,
						borderWidth: 2
					}]
				}
			});
		}

		document.querySelectorAll('#eventFilterPills button').forEach(btn => {
			btn.addEventListener('click', () => {

				document.querySelectorAll('#eventFilterPills button')
					.forEach(b => b.classList.remove('active'));
				btn.classList.add('active');

				const filter = btn.dataset.filter;

				document.querySelectorAll('.event-row').forEach(row => {
					const status = row.dataset.status;
					const collapseRow = row.nextElementSibling;

					const show =
						filter === 'all' ||
						(filter === 'cancelled' && status === 'cancelled') ||
						(filter === 'concluded' && status === 'concluded');

					row.style.display = show ? '' : 'none';

					if (collapseRow?.classList.contains('collapse')) {
						collapseRow.style.display = show ? '' : 'none';
					}
				});
			});
		});

	});

	function toggleEvent(btn) {
		const row = btn.closest('tr');
		const detailsRow = row.nextElementSibling;

		const isOpen = detailsRow.classList.toggle('open');

		// 🔥 THIS is the key
		row.classList.toggle('details-open', isOpen);

		btn.classList.toggle('active', isOpen);
	}

</script>
