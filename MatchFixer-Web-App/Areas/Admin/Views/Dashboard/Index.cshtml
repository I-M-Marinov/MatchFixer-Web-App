@using System.Globalization
@model MatchFixer_Web_App.Areas.Admin.ViewModels.AdminDashboardViewModel

@{
	Layout = "/Areas/Admin/Views/Shared/_Layout.Admin.cshtml";
	ViewData["Title"] = "Admin Dashboard";

	var wonPct = Model.TotalBets == 0 ? 0 : (int)Math.Round((double)Model.WonBets * 100 / Model.TotalBets);
	var lostPct = Model.TotalBets == 0 ? 0 : (int)Math.Round((double)Model.LostBets * 100 / Model.TotalBets);
	var pendingPct = Model.TotalBets == 0 ? 0 : 100 - wonPct - lostPct;

	var totalUsers = Model.TotalUsers == 0 ? 1 : Model.TotalUsers;
	var activePct = (int)Math.Round(Model.ActiveUsers * 100.0 / totalUsers);
	var lockedPct = (int)Math.Round(Model.LockedUsers * 100.0 / totalUsers);
	var bannedPct = (int)Math.Round(Model.BannedUsers * 100.0 / totalUsers);
	var inactivePct = 100 - activePct - lockedPct - bannedPct;

	inactivePct = Math.Clamp(inactivePct, 0, 100);

	var firstBetRow = true;
}

<div class="border-0 rounded-4 p-4 flex-fill">
	@if (TempData["SuccessMessage"] != null)
	{
		<div class="alert success-message" id="success-message">
			@TempData["SuccessMessage"]
		</div>
	}

	@if (TempData["ErrorMessage"] != null)
	{
		<div class="alert error-message" id="error-message">
			@TempData["ErrorMessage"]
		</div>
	}

</div>

<div class="background-profile"></div>

<div class="table-section d-flex flex-column" style="background-color: rgba(0, 0, 0, 0.3); padding: 1.5em 2em; border-radius: 0.35em; margin-top: 3em;">

	<div class="admin-metrics-grid">

		<!-- USERS -->
	    <div class="metric-card metric-users">
			<div class="metric-header">
				<i class="bi bi-people"></i>
				<span>Users</span>
			</div>

			<div class="metric-main">
				<div class="metric-value">@Model.TotalUsers</div>
				<div class="metric-label">Total Users</div>
			</div>

			<div class="metric-badges">
				<span class="badge bg-success">Active: @Model.ActiveUsers</span>
				<span class="badge bg-secondary">Inactive: @(Model.TotalUsers - Model.ActiveUsers)</span>
				<span class="badge bg-warning text-dark">Locked: @Model.LockedUsers</span>
				<span class="badge bg-dark">Deleted: @Model.DeletedUsers</span>
				<span class="badge bg-danger">Banned: @Model.BannedUsers</span>
			</div>

			<div class="metric-bar segmented">
				<div class="bar-fill bg-success" style="width:@activePct%">
					<span>@activePct%</span>
				</div>
				<div class="bar-fill bg-secondary" style="width:@inactivePct%">
					<span>@inactivePct%</span>
				</div>
				<div class="bar-fill bg-warning text-dark" style="width:@lockedPct%">
					<span>@lockedPct%</span>
				</div>
				<div class="bar-fill bg-danger" style="width:@bannedPct%">
					<span>@bannedPct%</span>
				</div>
			</div>

		</div>

		<!-- WALLETS -->
	    <div class="metric-card metric-wallets">
			<div class="metric-header">
				<i class="bi bi-wallet2"></i>
				<span>Wallets</span>
			</div>

			<div class="metric-main">
				<div class="metric-value">€@Model.TotalWalletBalance</div>
				<div class="metric-label">Total Balance</div>
			</div>

			<div class="metric-badges center">
				<span class="badge bg-info text-dark">
					Transactions: @Model.TotalTransactions
				</span>
			</div>

			<div class="metric-note">
				Total wallet balance is a sum of all user wallets.
			</div>
		</div>

		<!-- BETS -->
	    <div class="metric-card metric-bets">
			<div class="metric-header">
				<i class="bi bi-bar-chart-line"></i>
				<span>Bets</span>
			</div>

			<div class="metric-main">
				<div class="metric-value">@Model.TotalBets</div>
				<div class="metric-label">Total Bets Placed</div>
			</div>

			<div class="metric-badges">
				<span class="badge bg-warning text-dark">Pending: @Model.PendingBets</span>
				<span class="badge bg-success">Won: @Model.WonBets</span>
				<span class="badge bg-danger">Lost: @Model.LostBets</span>
			</div>

			<div class="metric-bar segmented">
				<div class="bar-fill bg-warning text-dark" style="width:@pendingPct%">
					<span>@pendingPct%</span>
				</div>
				<div class="bar-fill bg-success" style="width:@wonPct%">
					<span>@wonPct%</span>
				</div>
				<div class="bar-fill bg-danger" style="width:@lostPct%">
					<span>@lostPct%</span>
				</div>
			</div>


		</div>

	</div>

	<div class="admin-dashboard-grid mt-2">

	    <!-- PLATFORM EXPOSURE -->
	    <div class="admin-mini-card">
		    <div class="admin-mini-title">
			    <span class="text-warning animate__animated animate__heartBeat">
				    <i class="bi bi-exclamation-triangle"></i>
			    </span>
			    Platform Exposure
		    </div>

	        <div>Total stakes today</div>
	        <div class="admin-mini-value">
	            €@Model.Exposure.TotalStakesToday.ToString("N2")
	        </div>

	        <div>Potential payout</div>
	        <div class="admin-mini-value text-danger">
	            €@Model.Exposure.PotentialPayout.ToString("N2")
	        </div>

	        <div class="admin-mini-footer">
	            Exposure: €@Model.Exposure.Exposure.ToString("N2")
	        </div>
	    </div>


	    <!-- BET ACTIVITY -->
	    <div class="admin-mini-card">
		    <div class="admin-mini-title">
			    <span class="text-info animate__animated animate__heartBeat">
				    <i class="bi bi-activity"></i>
				</span>
			   
			    Bet Activity
		    </div>

	        <div class="admin-mini-row mt-5">
	            <span>Today</span>
	            <span>@Model.BetsActivity.BetsToday</span>
	        </div>

	        <div class="admin-mini-row">
	            <span>Yesterday</span>
	            <span>@Model.BetsActivity.BetsYesterday</span>
	        </div>

	        <div class="admin-mini-row">
	            <span>This week</span>
	            <span>@Model.BetsActivity.BetsThisWeek</span>
	        </div>
	    </div>


	    <!-- WALLET FLOW -->
	    <div class="admin-mini-card">
	        <div class="admin-mini-title">
				<i class="bi bi-wallet text-tomato animate__animated animate__heartBeat"></i>
	            Wallet Flow Today
	        </div>

	        <div class="admin-mini-row mt-5">
	            <span>Deposits</span>
	            <span class="text-success">
	                €@Model.WalletActivity.DepositsToday.ToString("N2")
	            </span>
	        </div>

	        <div class="admin-mini-row">
	            <span>Withdrawals</span>
	            <span class="text-danger">
	                €@Model.WalletActivity.WithdrawalsToday.ToString("N2")
	            </span>
	        </div>

	        <div class="admin-mini-row fw-bold">
	            <span>Net</span>
	            <span>
	                €@Model.WalletActivity.NetFlow.ToString("N2")
	            </span>
	        </div>
	    </div>
		
	    <!-- AVERAGE BET SIZE -->

	    <div class="admin-mini-card">
		    <div class="admin-mini-title">
				<i class="bi bi-graph-up text-primary animate__animated animate__heartBeat"></i>
			    Average Bet Size
		    </div>

		    @foreach (var avg in Model.AverageBetSizes)
		    {
			    <div class="admin-mini-row @(firstBetRow ? "mt-5" : "")">
				    <span>@avg.Period</span>
				    <span>€@avg.AverageAmount.ToString("N2")</span>
			    </div>

			    firstBetRow = false;
		    }
	    </div>

	    <!-- TOP WINNERS -->
	    @{
		    var fewWinnersResults = Model.TopWinners.Count <= 3;
		    var firstWinner = true;

	    }

	    <div class="admin-mini-card">
		    <div class="admin-mini-title">
			    <i class="bi bi-trophy text-warning animate__animated animate__heartBeat"></i>
			    Top Winners (48h)
		    </div>

		    @foreach (var w in Model.TopWinners)
		    {
				<div class="admin-mini-row @(fewWinnersResults && firstWinner ? "mt-5" : "")">

				    <a asp-area="Admin"
				       asp-controller="Users"
				       asp-action="ShowUsers"
				       asp-route-query="@w.Email"
				       class="text-decoration-none">

					    @w.Username
				    </a>

				    <span class="text-success">
					    +€@w.Profit.ToString("N2")
				    </span>

			    </div>

				firstWinner = false;
		    }
	    </div>


	    <!-- TOP LOSERS -->
	    @{
		    var fewResults = Model.TopLosers.Count <= 3;
		    var firstLoser = true;
	    }

	    <div class="admin-mini-card">
		    <div class="admin-mini-title">
				<i class="bi bi-emoji-frown text-danger animate__animated animate__heartBeat"></i>
			    Top Losers (48h)
		    </div>

		    @foreach (var l in Model.TopLosers)
		    {
				<div class="admin-mini-row @(fewResults && firstLoser ? "mt-5" : "")">

				    <a asp-area="Admin"
				       asp-controller="Users"
				       asp-action="ShowUsers"
				       asp-route-query="@l.Email"
				       class="text-decoration-none">

					    @l.Username
				    </a>

				    <span class="text-danger">
					    -€@l.Profit.ToString("N2")
				    </span>

			    </div>

			    firstLoser = false;

		    }
	    </div>


	    <!-- HOT MATCHES -->
	    <div class="admin-mini-card">
	        <div class="admin-mini-title">
		        <span class="boost-fire-icon">
			        <i class="bi bi-fire "></i>
		        </span>
	            Hot Matches ( 7 days )
	        </div>

	        @foreach (var m in Model.HotMatches)
	        {
	            <div class="admin-mini-row">
	                <span>
	                    @m.HomeTeam vs @m.AwayTeam
	                </span>

	                <span class="badge bg-dark">
	                    @m.BetsCount bets
	                </span>
	            </div>
	        }
	    </div>

	</div>

</div>

